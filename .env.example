# Wartelisten-Speicher: "json" (lokal) oder "supabase" (Produktion)
WAITLIST_PROVIDER=supabase

# Supabase (https://supabase.com)
NEXT_PUBLIC_SUPABASE_URL=https://dein-projekt.supabase.co
SUPABASE_SERVICE_ROLE_KEY=dein-service-role-key

# OpenAI – Demo-Analyse (serverseitig, niemals im Client!)
OPENAI_API_KEY=sk-dein-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# Plausible Analytics (optional, datenschutzfreundlich)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=deine-domain.de

# Canonical URL für SEO (optional)
NEXT_PUBLIC_SITE_URL=https://deine-domain.de
